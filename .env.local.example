# Supabase project credentials.
# Copy this file to .env.local and fill in the values from your Supabase
# dashboard: Project Settings -> API.

# Your project's REST URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The public "anon" API key (safe to expose in a client app).
VITE_SUPABASE_ANON_KEY=
